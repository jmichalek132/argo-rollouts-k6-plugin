# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Grafana Cloud k6 personal API token
# Generate at: Testing & Synthetics > Performance > Settings > Access > Personal token
K6_CLOUD_TOKEN=

# Numeric ID of your Grafana Cloud stack (visible in the k6 UI URL)
K6_STACK_ID=

# Numeric ID of the k6 load test to run for live e2e tests
# Create one with: k6 cloud run --project-id <id> examples/k6-plugin-demo.js
K6_TEST_ID=
